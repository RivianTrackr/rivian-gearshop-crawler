BREVO_API_KEY=your-brevo-api-key-here
EMAIL_FROM="Your Name <you@example.com>"
EMAIL_TO="you@example.com"
SITE_ROOT=https://gearshop.rivian.com
COLLECTION_URL=https://gearshop.rivian.com/collections/all
DB_PATH=/opt/rivian-gearshop-crawler/gearshop.db

# Discord (optional — leave blank to disable)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url-here

# Separate error notification webhook (optional — falls back to DISCORD_WEBHOOK_URL)
# ERROR_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-error-webhook-url-here

# Social media auto-posting (optional). Posts text+link when products are added
# or removed. Prefer the admin UI (Notifications page); these env vars are a
# fallback when no admin DB config exists. Leave blank to disable a platform.
#
# Bluesky — create an app password at https://bsky.app/settings/app-passwords
# BLUESKY_HANDLE=riviantrackr.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# X / Twitter — OAuth 1.0a keys from a developer App (Read and Write permission).
# Sign up at https://developer.x.com; a default Project + App is auto-created.
# Copy all four keys from the App's "Keys and tokens" tab. After switching App
# permissions to "Read and write", REGENERATE the access token/secret — tokens
# minted while read-only stay read-only and posting fails with HTTP 403.
# NOTE: X removed its free tier in 2026. Posting is pay-per-use and requires
# pre-purchased credits: ~$0.015 per text post, ~$0.20 per post containing a
# link (our new-product posts include the product URL). Bluesky and Threads
# have no per-post cost.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
#
# Threads — Meta app + Threads professional account, long-lived access token
# (https://developers.facebook.com/docs/threads)
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN=
#
# Post up to N products individually per run, then one summary post (default 5)
# SOCIAL_MAX_POSTS_PER_RUN=5

# Optional tuning
PRODUCT_DELAY=0.2
# MAX_SCROLL_SECONDS=120
# AVAIL_HTML_MAX=200
# HEARTBEAT_UTC_HOUR=-1
# CRAWLER_DEBUG=0
# JSON_OUT_PATH=/opt/rivian-gearshop-crawler/gearshop.json

# Admin UI
# ADMIN_SECRET_KEY=  (auto-generated on first setup if not set)
# ADMIN_PORT=8111
# ADMIN_DB_PATH=/opt/rivian-gearshop-crawler/admin.db
